<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/f"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_selectd"
    android:padding="@dimen/_9sdp">

    <RelativeLayout
        android:id="@+id/avatar_lay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/_8sdp">


        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/profile_progress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="true"
            android:max="100"
            android:visibility="gone"
            android:rotation="180"
            app:indicatorColor="@color/colorPrimary"
            app:indicatorDirectionCircular="clockwise"
            app:indicatorSize="@dimen/_47sdp"
            app:trackColor="@color/colorPrimary_low"
            app:trackThickness="@dimen/_3sdp" />

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/avatar"
            android:layout_width="@dimen/_42sdp"
            android:layout_height="@dimen/_42sdp"
            android:layout_centerInParent="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/profile_img"
            app:riv_corner_radius="@dimen/_77sdp" />

        <ImageView
            android:id="@+id/who_profile"
            android:layout_width="@dimen/_14sdp"
            android:layout_height="@dimen/_14sdp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/who"
            android:visibility="gone" />

    </RelativeLayout>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_toEndOf="@id/avatar_lay">

        <RelativeLayout
            android:id="@+id/name_lay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_33sdp">


            <TextView
                android:id="@+id/name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:layout_marginEnd="@dimen/_23sdp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/app_name"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/who_tag"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_12sdp"
                android:layout_centerInParent="true"
                android:layout_marginStart="-26dp"
                android:layout_toEndOf="@+id/name"
                android:contentDescription="@string/app_name"
                android:src="@drawable/who_tag"
                android:visibility="gone"
                app:tint="@color/colorPrimary" />


        </RelativeLayout>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/name_lay"
            android:layout_marginTop="@dimen/_3sdp">

            <ImageView
                android:id="@+id/call_type_icon"
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_12sdp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_call_green" />

            <TextView
                android:id="@+id/call_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_3sdp"
                android:text="Type"
                android:textColor="@color/sub_title_color"
                android:textSize="@dimen/_12ssp"
                tools:ignore="HardcodedText" />


            <TextView
                android:id="@+id/call_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8sdp"
                android:text="Date"
                android:textColor="@color/sub_title_color"
                android:textSize="@dimen/_12ssp"
                tools:ignore="HardcodedText" />

        </LinearLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/get_call"
            android:layout_width="@dimen/_33sdp"
            android:layout_height="@dimen/_33sdp"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="@dimen/_4sdp">

            <ImageView
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="@drawable/call_round_bg"
                android:contentDescription="@string/app_name"
                android:padding="@dimen/_7sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_call_fill"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/colorPrimary" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </RelativeLayout>

    <TextView
        android:id="@+id/phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/avatar_lay"
        android:textColor="@color/black"
        android:textSize="@dimen/_9ssp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/call_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:textColor="@color/black"
        android:textSize="@dimen/_8ssp"
        android:visibility="gone" />
</RelativeLayout>
